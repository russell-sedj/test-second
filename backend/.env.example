# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# Serveur
PORT=3000

# Admin (identifiants de connexion au dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGER_CE_MOT_DE_PASSE

# JWT (clé secrète pour signer les tokens — doit être longue et aléatoire)
JWT_SECRET=CHANGER_CETTE_CLE_SECRETE

# CORS — origines autorisées à appeler l'API (séparer par virgule si plusieurs)
# En développement : http://localhost:4200
# En production : https://votre-domaine.com
CORS_ORIGIN=http://localhost:4200

# Email (pour le formulaire de contact)
# Exemple avec Gmail : activer "Mots de passe d'application" dans les paramètres Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre.email@gmail.com
EMAIL_PASS=mot_de_passe_application_gmail
EMAIL_TO=email-reception-contact@email.com
